{
    "extends": "@react-native/typescript-config",
    "compilerOptions": {
        "types": ["jest"],
        "paths": {
            "@_assets/*": ["./src/assets/*"],
            "@_components": ["./src/components/index.tsx"],
            "@_hooks/*": ["./src/hooks/*"],
            "@_navigation/*": ["./src/navigation/*"],
            "@_screens": ["./src/screens/index.tsx"],
            "@_types/*": ["./src/types/*"],
            "@_utils/*": ["./src/utils/*"]
        }
    },
    "include": ["**/*.ts", "**/*.tsx", "nativewind-env.d.ts"],
    "exclude": ["**/node_modules", "**/Pods"]
}
